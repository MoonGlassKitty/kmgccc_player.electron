{
  "name": "mgkccc-player-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron translation of the kmgccc macOS 26 project by MoonGlassKitty.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win": "npm run build && electron-builder --win portable --x64",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.kmgccc.player.windows",
    "productName": "mgkccc",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@applemusic-like-lyrics/lyric": "^1.0.1",
    "@applemusic-like-lyrics/react": "^0.5.1",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "lucide-react": "^0.560.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "web-audio-beat-detector": "^8.2.36"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "optionalDependencies": {
    "@nodert-win11/windows.media": "^0.1.6",
    "@nodert-win11/windows.media.control": "^0.1.6",
    "@nodert-win11/windows.storage.streams": "^0.1.6"
  }
}
